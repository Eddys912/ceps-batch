# Gitignore for ceps-batch
# Documentation: https://git-scm.com/docs/gitignore

# Build output
dist/

# Dependencies
node_modules/

# Logs
npm-debug.log
yarn-debug.log
yarn-error.log
pnpm-debug.log

# Environment variables
.env
.env.production
.env.test
.env.local
*.local

# Temporary or backup files
*~
*.temp
*.tmp
*.bak

# Editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
